{
  "name": "pebol",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Draft de futebol 1v1 em tempo real",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx server/src/index.ts",
    "bot": "tsx server/src/bot.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
