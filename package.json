{
  "name": "pebol",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Draft de futebol 1v1 em tempo real",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "tsx server/src/index.ts",
    "bot": "tsx server/src/bot.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
