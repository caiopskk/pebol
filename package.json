{
  "name": "pebol",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Draft de futebol 1v1 em tempo real",
  "scripts": {
    "dev": "concurrently --kill-others --kill-signal SIGINT --kill-timeout 2000 --teardown \"pnpm run dev:stop\" -n server,client -c blue,green \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite",
    "dev:stop": "node scripts/kill-dev-ports.mjs",
    "build": "vite build",
    "start": "tsx server/src/index.ts",
    "bot": "tsx server/src/bot.ts",
    "test:engine": "tsx server/src/engine-property-test.ts",
    "test:engine:balance": "tsx server/src/engine-balance-test.ts",
    "test:engine:all": "pnpm run test:engine && pnpm run test:engine:balance",
    "test:manager": "tsx client/src/manager-career-test.ts",
    "test:modes": "tsx server/src/game-modes-test.ts && tsx client/src/campaign-mode-test.ts",
    "test:all": "pnpm run test:modes && pnpm run test:engine:all && pnpm run test:manager && pnpm run test:achievements && pnpm run test:clubs && pnpm run test:ball-motion",
    "test:ball-motion": "tsx client/src/ball-motion-test.ts",
    "test:achievements": "tsx client/src/achievement-rules-test.ts",
    "test:clubs": "tsx server/src/club-catalog-test.ts",
    "db:sync-worldcup-2026": "tsx scripts/sync-worldcup-2026.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@libsql/client": "^0.17.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bcryptjs": "^3.0.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "html-to-image": "^1.11.13",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.0.2",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
